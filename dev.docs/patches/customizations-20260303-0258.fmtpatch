+-}
+-
+-.cron-filter-dropdown__list {
+-  display: grid;
+-  gap: 6px;
+-}
+-
+-.cron-filter-dropdown__option {
+-  display: grid;
+-  grid-template-columns: 16px minmax(0, 1fr);
+-  gap: 8px;
+-  align-items: center;
+-  color: var(--text);
